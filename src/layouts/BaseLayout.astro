---
import '../styles/global.css';
import TopNav from '../components/TopNav.astro';
import Footer from '../components/Footer.astro';
import { siteMeta } from '../data/siteI18n';
const { title = 'Build Your Agentic Company', description = 'A public guide for building your own agentic company.' } = Astro.props;
---
<!doctype html>
<html lang="en" data-locale="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#efe7d2" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body>
    <div class="side-rail left" aria-hidden="true"><span data-i18n-en>{siteMeta.sideRails.left.en}</span><span data-i18n-id>{siteMeta.sideRails.left.id}</span></div>
    <div class="side-rail right" aria-hidden="true"><span data-i18n-en>{siteMeta.sideRails.right.en}</span><span data-i18n-id>{siteMeta.sideRails.right.id}</span></div>
    <div class="corner-frame" aria-hidden="true">
      <span class="corner tl"></span>
      <span class="corner tr"></span>
      <span class="corner bl"></span>
      <span class="corner br"></span>
    </div>
    <div class="site-shell">
      <TopNav />
      <slot />
      <Footer />
    </div>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const stored = localStorage.getItem('acs-locale');
        const initial = stored === 'id' ? 'id' : 'en';

        const applyLocale = (locale) => {
          const next = locale === 'id' ? 'id' : 'en';
          root.dataset.locale = next;
          root.lang = next;
          localStorage.setItem('acs-locale', next);
          for (const button of document.querySelectorAll('[data-locale-select]')) {
            const active = button.getAttribute('data-locale-select') === next;
            button.classList.toggle('is-active', active);
            button.setAttribute('aria-pressed', active ? 'true' : 'false');
          }
        };

        applyLocale(initial);
        for (const button of document.querySelectorAll('[data-locale-select]')) {
          button.addEventListener('click', () => applyLocale(button.getAttribute('data-locale-select')));
        }

      })();
    </script>
  </body>
</html>
