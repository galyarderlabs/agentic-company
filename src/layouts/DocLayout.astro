---
import BaseLayout from './BaseLayout.astro';
import { localizedDocs } from '../data/i18n';
import { docUi, readLabel } from '../data/siteI18n';
const { doc, docId } = Astro.props;
const docsEn = localizedDocs('en');
const docsId = localizedDocs('id');
const sidebarDocs = docsEn.map((item, index) => ({ en: item, id: docsId[index] }));
---
<BaseLayout title={`${doc.title} — Build Your Agentic Company`} description={doc.description}>
  <style is:inline>
    @media (max-width: 920px) {
      .doc-layout { grid-template-columns: 1fr; }
      .doc-layout .sidebar {
        position: sticky;
        top: 104px;
        z-index: 25;
        display: flex;
        max-height: none;
        overflow-x: auto;
        overflow-y: hidden;
        border-top: 1px solid var(--line-strong);
        border-bottom: 1px solid var(--line);
        padding: 0;
        background: rgba(239, 231, 210, .94);
        backdrop-filter: blur(16px) saturate(1.02);
        scrollbar-width: none;
      }
      .doc-layout .sidebar::-webkit-scrollbar { display: none; }
      .doc-layout .sidebar a {
        flex: 0 0 min(220px, 72vw);
        border-bottom: 0;
        border-right: 1px solid var(--line);
        padding: 11px 12px;
        font-size: 12px;
      }
      .doc-layout .sidebar a:hover,
      .doc-layout .sidebar a.active { padding-left: 12px; background: rgba(20,20,19,.035); }
    }

    @media (max-width: 640px) {
      .doc-layout .sidebar { top: 94px; }
      .doc-layout .sidebar a { flex-basis: min(188px, 74vw); padding: 10px 11px; font-size: 11.5px; }
      .doc-layout .sidebar a span { font-size: 10px; }
    }
  </style>
  <main class="doc-layout">
    <aside class="sidebar" aria-label={docUi.sidebarLabel.en}>
      {sidebarDocs.map((item) => (
        <a class={item.en.slug === doc.slug ? 'active' : ''} href={`/docs/${item.en.slug}/`}>
          <span><span data-i18n-en>{item.en.kicker}</span><span data-i18n-id>{item.id.kicker}</span></span><br /><span data-i18n-en>{item.en.title}</span><span data-i18n-id>{item.id.title}</span>
        </a>
      ))}
    </aside>
    <article class="article">
      <header class="article-hero">
        <div class="kicker"><span data-i18n-en>{doc.kicker} · {readLabel(doc.read, 'en')}</span><span data-i18n-id>{docId.kicker} · {readLabel(docId.read, 'id')}</span></div>
        <h1><span data-i18n-en>{doc.title}</span><span data-i18n-id>{docId.title}</span></h1>
        <p><span data-i18n-en>{doc.description}</span><span data-i18n-id>{docId.description}</span></p>
      </header>
      <div class="article-body">
        <slot />
      </div>
    </article>
  </main>
</BaseLayout>
